# ============================================================================
# BusinessOS — variaveis de ambiente (ADR 0001). Copie para `.env.local`
# (git-ignored) e preencha. Validado por zod em `lib/config.ts` (falha cedo no
# boot se algo obrigatorio faltar). NAO comitar segredos.
# ============================================================================

# --- Conteudo / seletor de persistencia ---
# 'file'     -> arquivos MD em content/ (dev/testes/rollback; nao exige Supabase).
# 'supabase' -> Postgres/Supabase multi-tenant (producao; exige as 3 chaves abaixo).
CONTENT_STORE=file
CONTENT_ROOT=content                     # raiz dos MD (modo file), relativo a cwd
FOUNDER_EMAIL=ruanbraz@overlens.com.br   # vira admin no signup; owner default no seed

# --- Supabase (OBRIGATORIAS quando CONTENT_STORE=supabase) ---
# Pegue em Project Settings > API do projeto Supabase. As NEXT_PUBLIC_* vao ao
# browser (RLS por sessao); a service_role e SERVER-ONLY (contorna a RLS) e nunca
# pode ir ao client.
NEXT_PUBLIC_SUPABASE_URL=                 # ex.: https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=           # chave publica (anon)
SUPABASE_SERVICE_ROLE_KEY=               # SECRETA — so server-side (admin/CLI/ETL)

# --- Storage (anexos) ---
SUPABASE_STORAGE_BUCKET=attachments      # bucket privado de anexos (default: attachments)

# --- IA (cabo solto) ---
# A presenca desta chave LIGA a IA no runtime (AI_ENABLED). Sem ela, a UI degrada
# com elegancia (acoes de IA desabilitadas). Provider: Anthropic via Vercel AI SDK.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Nota: apenas ANTHROPIC_API_KEY e lida por lib/config.ts. Outras chaves de modelo
# (OPENAI_API_KEY, GEMINI_API_KEY) nao sao usadas nesta fase.

GOOGLE_GENERATIVE_AI_API_KEY=